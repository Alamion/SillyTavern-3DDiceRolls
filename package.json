{
  "name": "3d-dice-roller",
  "author": "Alamion",
  "version": "1.3.2",
  "private": true,
  "packageManager": "pnpm@9.7.1",
  "dependencies": {
    "cannon-es": "^0.20.0",
    "moo": "^0.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  },
  "peerDependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.160.0"
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "build:scss": "sass --no-source-map src/styles:dist/styles",
    "watch:scss": "sass --no-source-map --watch src/styles:dist/styles",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@eslint/js": "^9.0.0",
    "@types/cannon": "^0.1.13",
    "@types/moo": "^0.5.10",
    "@types/node": "^25.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.183.1",
    "@types/toastr": "^2.1.43",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.4",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.4.0",
    "html-loader": "^5.1.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "sass": "^1.83.0",
    "sass-loader": "^16.0.4",
    "seedrandom": "^3.0.5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.17",
    "toastr": "^2.1.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.7",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4"
  }
}
